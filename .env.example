# GitLab Personal Access Token (requires 'api' scope)
GITLAB_TOKEN=glpat-xxxxxxxxxxxxxxxxxxxx

# GitHub Personal Access Token
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxx

# Anthropic API Key (default provider)
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxx

# Google Gemini API Key (if using --provider gemini)
# GEMINI_API_KEY=your-gemini-api-key

# Ollama host (if using --provider ollama)
# OLLAMA_HOST=http://localhost:11434

# Optional: AI provider (anthropic, gemini, ollama)
# MR_REVIEWER_PROVIDER=anthropic

# Optional: AI model override
# MR_REVIEWER_MODEL=claude-sonnet-4-20250514

# Optional: default review focus areas
# MR_REVIEWER_FOCUS=bugs,style,best-practices

# Optional: enable parallel review mode
# MR_REVIEWER_PARALLEL=false

# Optional: minimum changed files to trigger parallel mode
# MR_REVIEWER_PARALLEL_THRESHOLD=10
